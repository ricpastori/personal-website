{
  // Wrangler v3+ schema
  "$schema": "https://developers.cloudflare.com/wrangler/schema.json",

  // Project name (used by wrangler, not public-facing)
  "name": "ricpastori-site",

  // Pages project (not Workers)
  "pages_build_output_dir": "public",

  // Compatibility date is mandatory in modern CF tooling
  // Pick a date and update consciously, not automatically
  "compatibility_date": "2025-01-15"
}