{
  "files": {
    "includes": ["assets/**/*.js", "assets/**/*.css", "layouts/**/*.html"]
  },
  "linter": {
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "attributePosition": "auto",
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "css": {
    "linter": {
      "noDuplicateProperties": "safe"
    }
  }
}
