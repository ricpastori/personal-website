# ============================================================================
# HUGO — Generated output
# ============================================================================

# Final static site output
/public/

# Hugo image / asset pipeline cache
/resources/_gen/

# Hugo build lock file
.hugo_build.lock


# ============================================================================
# Generated project drafts (custom Node script)
# ============================================================================

# YAML generated by scripts/generate-projects-drafts.mjs
# This is a build artifact and must never be committed.
assets/__generated/project-drafts.yaml


# ============================================================================
# Node (used only as a tooling layer)
# ============================================================================

# If you ever install dependencies locally
/node_modules/

# Optional: if you add a package.json later
package-lock.json
pnpm-lock.yaml
yarn.lock

# Node logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ============================================================================
# Environment variables
# ============================================================================

# Local environment files
.env
.env.local
.env.development
.env.production


